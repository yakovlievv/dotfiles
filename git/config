[include]
	path = /Users/yako/dotfiles/git/catppuccin.gitconfig

[user]
	name = yakovlievv
	email = yakovlievv25@gmail.com

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	features = catppuccin-mocha
    syntax-theme = "Catppuccin Mocha"

[merge]
	conflictStyle = zdiff3

[init]
	defaultBranch = main

[diff]
	algorithm = histogram

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rerere]
	enabled = true

[pull]
	rebase = true
